{
  "name": "prd_prompt_classifier_call",
  "purpose": "Classify a user's raw product requirement prompt before PRD generation. This call must only return classification tags, confidence, assumptions, and missing-context tags. It must not generate PRD content, ask follow-up questions, design architecture, or create sprint tasks.",
  "model": "gpt-5.5-thinking",
  "temperature": 0.1,
  "input": {
    "user_prompt": "{{USER_PROMPT}}"
  },
  "system_prompt": "You are a PRD intake classifier. Your only job is to classify the user's raw product idea or requirement into structured tags that will be used by a later question-generation step. Do not generate a PRD. Do not ask questions. Do not provide explanations. Do not include system design, architecture, database, API, sprint planning, implementation details, or recommendations. Return only valid JSON matching the schema.",
  "user_prompt_template": "Classify this product requirement prompt into structured PRD intake tags only:\n\n{{USER_PROMPT}}",
