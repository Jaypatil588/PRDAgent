# Copy to .env and fill in your values:
#   cp .env.example .env
#
# Get a Groq API key: https://console.groq.com/keys

# Required — server-side only (never expose to the browser)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Model roles (Groq model IDs)
MODEL_JSON=openai/gpt-oss-20b
MODEL_PRD=openai/gpt-oss-120b
MODEL_SEARCH=groq/compound
MODEL_ENUM=groq/compound,groq/compound-mini

# Used when primary model hits quota (429 TPD) or request too large (413)
MODEL_FALLBACK=llama-3.1-8b-instant

# Max prompt tokens per request; upstream doc grounding is trimmed to fit
MAX_INPUT_TOKENS=7500

# Optional — API listen port (default 3001)
# PORT=3001
